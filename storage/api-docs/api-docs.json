        "/register": {
            "post": {
                "tags": [
                    "Autentikasi"
                ],
                "summary": "Mendaftarkan akun baru (Mahasiswa / Dosen / Eksternal)",
                "description": "Dikelola oleh Laravel Fortify. Setelah berhasil, user langsung diarahkan ke halaman dashboard (redirect web, bukan JSON).",
                "operationId": "b01bde3585c85b9191877089895a20aa",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "identitas",
                                    "email",
                                    "kategori_pendaftar",
                                    "password",
                                    "password_confirmation"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Budi Santoso"
                                    },
                                    "identitas": {
                                        "description": "NIM / NIP / NIPH / Identitas lainnya",
                                        "type": "string",
                                        "example": "04231011"
                                    },
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "budi@student.itk.ac.id"
                                    },
                                    "kategori_pendaftar": {
                                        "type": "string",
                                        "example": "mahasiswa",
                                        "enum": [
                                            "mahasiswa",
                                            "dosen",
                                            "eksternal"
                                        ]
                                    },
                                    "program_studi": {
                                        "description": "Wajib diisi jika kategori mahasiswa/dosen",
                                        "type": "string",
                                        "example": "Teknik Elektro",
                                        "nullable": true
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "secret123"
                                    },
                                    "password_confirmation": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "secret123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "302": {
                        "description": "Redirect ke dashboard setelah registrasi berhasil"
                    },
                    "422": {
                        "description": "Validasi gagal — data tidak lengkap atau tidak sesuai format"
                    }
                },
                "servers": [
                    {
                        "url": "http://localhost:8000",
                        "description": "Server Pengembangan Lokal"
                    }
                ]
            }
        },
        "/login": {
