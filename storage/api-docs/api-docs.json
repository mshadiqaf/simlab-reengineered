                                    "password"
                                ],
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "example": "budi@student.itk.ac.id"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "example": "secret123"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "302": {
                        "description": "Redirect ke dashboard setelah login berhasil"
                    },
                    "422": {
                        "description": "Kredensial salah"
                    }
                },
                "servers": [
                    {
                        "url": "http://localhost:8000",
                        "description": "Server Pengembangan Lokal"
                    }
                ]
            }
        },
