                "responses": {
                    "200": {
                        "description": "Data user berhasil diambil",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "data": {
                                            "properties": {
                                                "id": {
                                                    "type": "integer",
                                                    "example": 1
                                                },
                                                "name": {
                                                    "type": "string",
                                                    "example": "Budi Santoso"
                                                },
                                                "nim": {
                                                    "type": "string",
                                                    "example": "04231011"
                                                },
                                                "program_studi": {
                                                    "type": "string",
                                                    "example": "Teknik Elektro"
                                                },
                                                "email": {
                                                    "type": "string",
                                                    "example": "budi@student.itk.ac.id"
                                                },
                                                "roles": {
                                                    "type": "array",
                                                    "items": {
                                                        "type": "string"
                                                    },
                                                    "example": [
                                                        "Mahasiswa"
                                                    ]
                                                }
                                            },
                                            "type": "object"
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthenticated — User belum login"
                    }
                },
                "security": [
                    {
                        "cookieAuth": []
                    }
                ]
            }
        },
        "/api/ketersediaan": {
            "get": {
                "tags": [
                    "Master Data"
                ],
                "summary": "Kalender ketersediaan ruangan, alat, dan pengujian per bulan",
                "description": "Mengembalikan data peminjaman/pengajuan yang distrukturisasi per tanggal dalam satu bulan. Cocok untuk tampilan kalender di frontend. Dapat difilter berdasarkan tipe dan kata kunci nama. Endpoint ini PUBLIK — tidak memerlukan login.",
                "operationId": "e61cdf7c2d819a5410c1e13c5286fafc",
                "parameters": [
                    {
                        "name": "bulan",
                        "in": "query",
                        "description": "Bulan yang ingin dilihat, format YYYY-MM",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "example": "2026-05"
                        }
                    },
                    {
                        "name": "tipe",
                        "in": "query",
                        "description": "Filter berdasarkan tipe: ruangan, alat, atau pengujian",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "ruangan",
                                "alat",
                                "pengujian"
                            ]
                        }
                    },
                    {
                        "name": "cari",
                        "in": "query",
                        "description": "Kata kunci pencarian nama ruangan/alat/jenis pengujian",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "example": "Fisika"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Data kalender ketersediaan berhasil diambil",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "properties": {
                                        "bulan": {
                                            "type": "string",
                                            "example": "2026-05"
                                        },
                                        "filter": {
                                            "properties": {
                                                "tipe": {
                                                    "type": "string",
                                                    "example": "ruangan",
                                                    "nullable": true
                                                },
                                                "cari": {
                                                    "type": "string",
                                                    "example": "Fisika",
                                                    "nullable": true
                                                }
                                            },
                                            "type": "object"
                                        },
                                        "kalender": {
                                            "description": "Key = tanggal (YYYY-MM-DD), value = array booking pada hari tersebut",
                                            "type": "object",
                                            "example": {
                                                "2026-05-01": [
                                                    {
                                                        "tipe": "ruangan",
                                                        "nama": "Lab. Fisika Dasar A (R202)",
                                                        "waktu_mulai": "08:00",
                                                        "waktu_selesai": "12:00",
                                                        "status": "disetujui"
                                                    }
                                                ],
                                                "2026-05-03": [
                                                    {
                                                        "tipe": "alat",
                                                        "nama": "Osiloskop Digital",
                                                        "jumlah": 3,
                                                        "status": "diverifikasi"
                                                    }
                                                ],
                                                "2026-05-07": []
                                            }
                                        }
                                    },
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Format bulan tidak valid"
                    }
                }
            }
        },
